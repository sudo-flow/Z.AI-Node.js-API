# Environment Configuration
NODE_ENV=development
PORT=3000

# Default Provider API Configuration
# This is the primary API provider for GLM models
DEFAULT_PROVIDER_API_KEY=your_default_provider_api_key
DEFAULT_PROVIDER_BASE_URL=https://api.z.ai/api/coding/paas/v4/
DEFAULT_PROVIDER_TIMEOUT=300000

# OpenRouter API Configuration (Optional)
# For accessing additional models like Amazon Nova, Qwen, etc.
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Legacy Z.AI env vars (for backward compatibility)
# These will be deprecated in future versions
ZAI_API_KEY=${DEFAULT_PROVIDER_API_KEY}
ZAI_BASE_URL=${DEFAULT_PROVIDER_BASE_URL}
ZAI_TIMEOUT=${DEFAULT_PROVIDER_TIMEOUT}

# CORS Configuration
CORS_ORIGINS=*

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_PRETTY_PRINT=true

# Redis (Optional)
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Monitoring
METRICS_ENABLED=true
HEALTH_CHECK_INTERVAL=30000